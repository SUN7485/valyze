# Environment Variables - Copy to .env and customize

# LM Studio (optional - system works without AI)
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# Database
DATABASE_URL=sqlite+aiosqlite:///./antigravity.db

# Upload Settings
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100

# Chunk Settings (for RAG)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_CHUNKS=3

# Tesseract OCR (Windows: C:/Program Files/Tesseract-OCR/tesseract.exe)
# macOS: /usr/local/bin/tesseract or /opt/homebrew/bin/tesseract
TESSERACT_CMD=

# AI Settings
AI_BATCH_SIZE=5

# Gotenberg (PDF conversion - optional)
GOTENBERG_URL=http://localhost:3000