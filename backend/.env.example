# =============================================================================
# Valyze Credit Backend — Environment Variables
# =============================================================================
# Copy to .env and customize. NEVER commit .env to git.
# For production, set these in Render Dashboard → Environment Variables.
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase (REQUIRED)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ---------------------------------------------------------------------------
# Frontend URL (for CORS — set in Render Dashboard)
# Example: https://your-app.vercel.app
# ---------------------------------------------------------------------------
FRONTEND_URL=

# ---------------------------------------------------------------------------
# Extra CORS Origins (comma-separated, optional)
# Example: https://preview-abc.vercel.app,https://staging.example.com
# ---------------------------------------------------------------------------
CORS_EXTRA_ORIGINS=

# ---------------------------------------------------------------------------
# Gotenberg (PDF conversion — optional, Playwright is used as fallback)
# Set to empty string in production to use Playwright
# ---------------------------------------------------------------------------
GOTENBERG_URL=

# ---------------------------------------------------------------------------
# LM Studio (optional — AI extraction, not needed for production)
# ---------------------------------------------------------------------------
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=qwen/qwen3.5-9b

# ---------------------------------------------------------------------------
# Upload Settings
# ---------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100

# ---------------------------------------------------------------------------
# Tesseract OCR
# ---------------------------------------------------------------------------
# Linux (Docker): /usr/bin/tesseract
# Windows: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=/usr/bin/tesseract

# ---------------------------------------------------------------------------
# App Config
# ---------------------------------------------------------------------------
ENV=production
LOG_LEVEL=INFO