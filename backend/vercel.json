{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/health",    "dest": "/api/index.py" },
    { "src": "/ready",     "dest": "/api/index.py" },
    { "src": "/api/(.*)",  "dest": "/api/index.py" },
    { "src": "/(.*)",      "dest": "/api/index.py" }
  ]
}