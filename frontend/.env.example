# =============================================================================
# Valyze Credit Frontend — Environment Variables
# =============================================================================
# Copy to .env and customize. NEVER commit .env to git.
# For Vercel: set these in Vercel Dashboard → Settings → Environment Variables
# =============================================================================

# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ---------------------------------------------------------------------------
# API Backend URL
# ---------------------------------------------------------------------------
# Local:  http://localhost:8000
# Prod:   https://valyze-backend.vercel.app  (NO trailing slash!)
VITE_API_BASE_URL=http://localhost:8000
