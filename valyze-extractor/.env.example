# Get your Anthropic API key from: https://console.anthropic.com/settings/keys
# Replace {{ANTHROPIC_API_KEY}} with your actual key (starts with "sk-ant-")
VITE_ANTHROPIC_API_KEY={{ANTHROPIC_API_KEY}}

# ---------------------------------------------------------------------------
# Auth API URL (for JWT token verification)
# ---------------------------------------------------------------------------
# Production: https://valyze-backend.vercel.app/api/auth/verify
# Leave empty to use default
VITE_AUTH_API=https://valyze-backend.vercel.app/api/auth/verify

# ---------------------------------------------------------------------------
# Proxy Server URL (Claude API proxy, runs on separate port)
# ---------------------------------------------------------------------------
# Local:  http://localhost:8000/api/proxy   (when running uvicorn locally)
#         http://localhost:3001/proxy       (old Node.js proxy — deprecated)
# Prod:   https://valyze-backend.vercel.app/api/proxy
# Leave empty to send requests DIRECTLY from browser (⚠ CORS issues in prod)
VITE_PROXY_URL=https://valyze-backend.vercel.app/api/proxy

# ---------------------------------------------------------------------------
# Frontend URL (where to redirect after extraction completes)
# ---------------------------------------------------------------------------
# IMPORTANT: This tells the extractor where to send you after extraction.
# Without this, redirects will fail in production.
#
# Local:  http://localhost:1573
# Prod:   https://valyze-front.vercel.app
VITE_FRONTEND_URL=https://valyze-front.vercel.app