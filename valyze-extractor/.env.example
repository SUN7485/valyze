# ---------------------------------------------------------------------------
# Deprecated standalone extractor environment
# ---------------------------------------------------------------------------
# The extractor is now embedded in the main frontend at /extractor.
# This file is kept only for legacy/local fallback runs.

# ---------------------------------------------------------------------------
# Auth API URL (for JWT token verification)
# ---------------------------------------------------------------------------
# Production: https://valyze-backend.vercel.app/api/auth/verify
# Leave empty to use default
VITE_AUTH_API=https://valyze-backend.vercel.app/api/auth/verify

# ---------------------------------------------------------------------------
# Proxy Server URL (Claude API proxy)
# ---------------------------------------------------------------------------
# Local:  http://localhost:8000/api/proxy
# Prod:   https://valyze-backend.vercel.app/api/proxy
VITE_PROXY_URL=https://valyze-backend.vercel.app/api/proxy

# ---------------------------------------------------------------------------
# Frontend URL (where to redirect after extraction completes)
# ---------------------------------------------------------------------------
# Local:  http://localhost:1573
# Prod:   https://valyze-frontend.vercel.app
VITE_FRONTEND_URL=https://valyze-frontend.vercel.app